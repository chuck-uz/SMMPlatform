DATABASE_URL="postgresql://app:devpassword@db:5432/smmplatform?schema=public"

NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="generate-a-random-32-byte-secret"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="set-a-real-password"

# 32 random bytes, base64-encoded — used to encrypt stored OAuth tokens (IG2+).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="generate-a-random-32-byte-base64-key"

# Production (DockHost example):
# NEXTAUTH_URL=https://smm.oresh.in
# DATABASE_URL=postgresql://postgres:CHANGE@smm-db:5432/smmplatform?schema=public
