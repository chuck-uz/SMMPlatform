// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connectedInstagramAccounts InstagramAccount[]

  @@map("users")
}

model InstagramAccount {
  id               String   @id @default(cuid())
  instagramUserId  String   @unique
  username         String
  accessToken      String
  tokenExpiresAt   DateTime
  connectedByUserId String
  connectedByUser  User     @relation(fields: [connectedByUserId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  media            InstagramMedia[]
  metricSnapshots  InstagramMetricSnapshot[]
  insightReports   AccountInsightReport[]

  @@map("instagram_accounts")
}

model InstagramMedia {
  id                String   @id @default(cuid())
  instagramMediaId  String   @unique
  accountId         String
  account           InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  mediaType         String
  mediaProductType  String?
  caption           String?
  permalink         String?
  postedAt          DateTime
  likeCount         Int      @default(0)
  commentsCount     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  comments          InstagramComment[]
  metricSnapshots   InstagramMetricSnapshot[]

  @@index([accountId])
  @@map("instagram_media")
}

model InstagramComment {
  id                  String   @id @default(cuid())
  instagramCommentId  String   @unique
  mediaId             String
  media               InstagramMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  text                String
  username            String?
  postedAt            DateTime
  createdAt           DateTime @default(now())

  replyStatus         String   @default("pending")
  draftReply          String?
  repliedAt           DateTime?
  sentReplyId         String?

  @@index([mediaId])
  @@index([replyStatus])
  @@map("instagram_comments")
}

model InstagramMetricSnapshot {
  id          String   @id @default(cuid())
  accountId   String
  account     InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  mediaId     String?
  media       InstagramMedia? @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  scope       String
  metrics     Json
  capturedAt  DateTime @default(now())

  @@index([accountId, scope, capturedAt])
  @@index([mediaId])
  @@map("instagram_metric_snapshots")
}

model AccountInsightReport {
  id          String   @id @default(cuid())
  accountId   String
  account     InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodFrom  DateTime
  periodTo    DateTime
  trigger     String
  content     Json
  createdAt   DateTime @default(now())

  @@index([accountId, trigger, createdAt])
  @@map("account_insight_reports")
}

model AgentConfig {
  id                        String   @id @default(cuid())
  singleton                 String   @unique @default("agent")
  toneAndRules              String   @default("")
  commentToneAndRules       String   @default("")
  commentModerationEnabled  Boolean  @default(true)
  updatedAt                 DateTime @updatedAt

  @@map("agent_config")
}

model AgentKnowledgeDocument {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agent_knowledge_documents")
}

model AgentExampleDialogue {
  id        String   @id @default(cuid())
  turns     Json
  createdAt DateTime @default(now())

  @@map("agent_example_dialogues")
}

model AgentSandboxSession {
  id         String   @id @default(cuid())
  turns      Json
  leadFields Json?
  model      String   @default("claude-haiku-4-5-20251001")
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("agent_sandbox_sessions")
}

model Lead {
  id             String   @id @default(cuid())
  conversationId String   @unique
  destination    String?
  people         String?
  dates          String?
  budget         String?
  contact        String?
  wishes         String?
  completeness   String   @default("partial")
  status         String   @default("new")
  source         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@map("leads")
}

model TelegramBotConfig {
  id               String    @id @default(cuid())
  singleton        String    @unique @default("telegram")
  encryptedBotToken String
  verified         Boolean   @default(false)
  verifiedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("telegram_bot_config")
}

model TelegramNotificationRecipient {
  id        String   @id @default(cuid())
  chatId    String   @unique
  label     String?
  createdAt DateTime @default(now())

  @@map("telegram_notification_recipients")
}

model LlmProviderCredential {
  id              String    @id @default(cuid())
  provider        String    @unique
  encryptedApiKey String
  verified        Boolean   @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("llm_provider_credentials")
}

model LlmRouteConfig {
  id              String   @id @default(cuid())
  interactionType String   @unique
  provider        String
  model           String
  updatedAt       DateTime @updatedAt

  @@map("llm_route_configs")
}

model ModelComparisonRun {
  id             String   @id @default(cuid())
  scenarioSource String
  scenarioTurns  Json
  createdAt      DateTime @default(now())

  results ModelComparisonResult[]

  @@index([createdAt])
  @@map("model_comparison_runs")
}

model ModelComparisonResult {
  id           String             @id @default(cuid())
  runId        String
  run          ModelComparisonRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  provider     String
  model        String
  turnIndex    Int
  reply        String?
  fields       Json?
  mechanism    String
  retries      Int                @default(0)
  latencyMs    Int
  inputTokens  Int?
  outputTokens Int?
  error        String?
  createdAt    DateTime           @default(now())

  @@index([runId])
  @@map("model_comparison_results")
}
